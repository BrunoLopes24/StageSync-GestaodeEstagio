# Database
DB_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql://stagesync:your_secure_password_here@localhost:5432/stagesync

# Backend
NODE_ENV=development
PORT=3000

# Frontend (Vite)
VITE_API_URL=http://localhost:3000/api/v1

# Authentication
JWT_ACCESS_SECRET=change-me-to-random-64-char-hex
JWT_REFRESH_SECRET=change-me-to-different-random-64-char-hex
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
ALLOW_FIRST_LOGIN_PASSWORD_SETUP=true
ALLOW_MULTIPLE_SESSIONS=true
